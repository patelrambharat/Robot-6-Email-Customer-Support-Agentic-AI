    <bpmn:sequenceFlow id="edge_jScmyl" sourceRef="Event_start" targetRef="Gateway_4gKHB2" />
    <bpmn:sequenceFlow id="edge_PIt2Op" name="Eugene must reply" sourceRef="Gateway_4gKHB2" targetRef="Activity_NN6OEb" />
    <bpmn:sequenceFlow id="edge_Zs162I" name="Ram must reply" sourceRef="Gateway_4gKHB2" targetRef="Activity_WCxQAh">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.response.Body.Contains("Ask Ram to reply")</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="edge_hWpaQl" sourceRef="Activity_WCxQAh" targetRef="Event_OVZoBF" />
    <bpmn:sequenceFlow id="edge_jDpSqC" sourceRef="Activity_tKS5xt" targetRef="Event_OVZoBF" />
