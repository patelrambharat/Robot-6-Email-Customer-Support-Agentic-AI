    <bpmn:serviceTask id="Activity_NN6OEb" name="Answer the question">
      <bpmn:documentation>UiPath answer the question UiPath Eugene Technical UiPath Question</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Orchestrator.StartAgentJob" version="v2" />
          <uipath:context>
            <uipath:input name="name" type="string" value="=bindings.bGU9phtu2" />
            <uipath:input name="folderPath" type="string" value="=bindings.b5zIBzQ2i" />
            <uipath:input name="_label" type="string" value="UiPath Eugene" />
            <uipath:inputSchema type="jsonSchema"><![CDATA[{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"sender_name":{"type":"string"},"sender_email":{"type":"string"},"email_subject":{"type":"string"},"email_body":{"type":"string"},"email_id":{"type":"string"}},"required":[]}]]></uipath:inputSchema>
          </uipath:context>
          <uipath:input name="JobArguments" type="json" target="bodyField"><![CDATA[{"sender_name":"=vars.response.From.Name","sender_email":"=vars.response.From.Email","email_subject":"=vars.response.Subject","email_body":"=vars.response.Body","email_id":"=vars.response.ID"}]]></uipath:input>
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error2" />
          <uipath:output name="content" type="string" source="=content" var="content" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>edge_PIt2Op</bpmn:incoming>
      <bpmn:outgoing>edge_VW4xRZ</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:sendTask id="Activity_tKS5xt" name="Reply to the mail">
      <bpmn:documentation>Email gets send with Eugene's agent</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Intsvc.ActivityExecution" version="v1" />
          <uipath:context>
            <uipath:input name="connectorKey" type="string" value="uipath-google-gmail" />
            <uipath:input name="connection" type="string" value="=bindings.b1wLTLxiB" />
            <uipath:input name="folderKey" type="string" value="=bindings.bYmBnDqkG" />
            <uipath:input name="resourceKey" type="string" value="e43f5801-28ea-49f5-93d2-447879039828" />
            <uipath:input name="operation" type="string" value="ReplyToEmailV2" />
            <uipath:input name="objectName" type="string" value="EmailReply" />
            <uipath:input name="method" type="string" value="POST" />
            <uipath:input name="path" type="string" value="/EmailReply" />
            <uipath:input name="metadata" type="json"><![CDATA[{"designTimeMetadata":{"connectorLogoUrl":"https://cloud.uipath.com/elements_/scaleunit_/58cb4f17-4581-4130-a2ae-52448b37dc03/v3/element/elements/uipath-google-gmail/image","activityDesignerVersion":"2","activityDisplayName":"Reply to Email","activityDescription":"Sends a reply to an email based on email ID","activityHelpUrlTemplate":"https://docs.uipath.com/{0}/activities/other/latest/integration-service/uipath-google-gmail-Reply-To-Email","activityConfig":{"isCurated":true,"operation":null}},"metadataState":{"jsonSchema":{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"threadId":{"title":"Email thread identifier","type":"string","description":"Unique identifier for the email conversation thread."},"labelIds[*]":{"title":"Label identifiers","type":"string","description":"Unique identifiers for the labels associated with the email."},"id":{"title":"Email identifier","type":"string","description":"A unique identifier for the email message."}},"definitions":{}}},"telemetryData":{"operationType":"Create","objectName":"EmailReply","objectDisplayName":"Email Reply","connectorKey":"uipath-google-gmail","connectorName":"Gmail","primaryKeyName":"id"},"inputMetadata":{"type":"multipart","multipart":{"bodyFieldName":"body"}},"errorState":{"hasError":false},"bindings":[]}]]></uipath:input>
          </uipath:context>
          <uipath:input name="replyToAll" type="string" value="true" target="query" />
          <uipath:input name="saveAsDraft" type="string" value="false" target="query" />
          <uipath:input name="id" type="string" value="=vars.response.ID" target="query" />
          <uipath:input name="body" type="json" target="body"><![CDATA[{"importance":"normal","body":"=vars.content.Replace(\". \",\".<br><br>\") ","subject":"=vars.response.Subject"}]]></uipath:input>
          <uipath:output name="id" type="string" source="=response.id" var="id" />
          <uipath:output name="response" type="jsonSchema" source="=response" var="response2" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error3" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>edge_VW4xRZ</bpmn:incoming>
      <bpmn:outgoing>edge_jDpSqC</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:exclusiveGateway id="Gateway_4gKHB2" name="who must reply?" default="edge_PIt2Op">
      <bpmn:incoming>edge_jScmyl</bpmn:incoming>
      <bpmn:outgoing>edge_PIt2Op</bpmn:outgoing>
      <bpmn:outgoing>edge_Zs162I</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:sendTask id="Activity_WCxQAh" name="Forward Email to Ram">
      <bpmn:documentation>Student requested to Ram to reply</bpmn:documentation>
      <bpmn:extensionElements>
        <uipath:activity version="v1">
          <uipath:type value="Intsvc.ActivityExecution" version="v1" />
          <uipath:context>
            <uipath:input name="connectorKey" type="string" value="uipath-google-gmail" />
            <uipath:input name="connection" type="string" value="=bindings.b1wLTLxiB" />
            <uipath:input name="folderKey" type="string" value="=bindings.bYmBnDqkG" />
            <uipath:input name="resourceKey" type="string" value="e43f5801-28ea-49f5-93d2-447879039828" />
            <uipath:input name="operation" type="string" value="ForwardMailV2" />
            <uipath:input name="objectName" type="string" value="ForwardMailV2" />
            <uipath:input name="method" type="string" value="POST" />
            <uipath:input name="path" type="string" value="/ForwardMailV2" />
            <uipath:input name="metadata" type="json"><![CDATA[{"designTimeMetadata":{"connectorLogoUrl":"https://cloud.uipath.com/elements_/scaleunit_/58cb4f17-4581-4130-a2ae-52448b37dc03/v3/element/elements/uipath-google-gmail/image","activityDesignerVersion":"2","activityDisplayName":"Forward Email","activityDescription":"Forwards an email in Gmail to another recipient","activityHelpUrlTemplate":"https://docs.uipath.com/{0}/activities/other/latest/integration-service/uipath-google-gmail-Forward-Email","activityConfig":{"isCurated":true,"operation":null}},"metadataState":{"jsonSchema":{"$schema":"http://json-schema.org/draft-07/schema#","type":"object","properties":{"threadId":{"title":"Email thread identifier","type":"string","description":"A unique identifier for the email thread."},"labelIds[*]":{"title":"Email label identifiers","type":"string","description":"A list of identifiers for labels associated with the email."},"id":{"title":"Email ID","type":"string","description":"A unique identifier for the specific email message."}},"definitions":{}}},"telemetryData":{"operationType":"Create","objectName":"ForwardMailV2","objectDisplayName":"Email","connectorKey":"uipath-google-gmail","connectorName":"Gmail","primaryKeyName":"id"},"inputMetadata":{"type":"multipart","multipart":{"bodyFieldName":"body"}},"errorState":{"hasError":false},"bindings":[]}]]></uipath:input>
          </uipath:context>
          <uipath:input name="saveAsDraft" type="string" value="false" target="query" />
          <uipath:input name="id" type="string" value="=vars.id" target="query" />
          <uipath:input name="body" type="json" target="body"><![CDATA[{"to":"patelmmmut12497@gmail.com","body":"<p class=\"editor-paragraph\" dir=\"ltr\"><span style=\"white-space: pre-wrap;\">\"Hi Ram please reply as requested by students.\"</span></p><p class=\"editor-paragraph\" dir=\"ltr\"><br></p><p class=\"editor-paragraph\" dir=\"ltr\"><span style=\"white-space: pre-wrap;\">Regards,</span></p><p class=\"editor-paragraph\" dir=\"ltr\"><span style=\"white-space: pre-wrap;\">Eugene</span></p>"}]]></uipath:input>
          <uipath:output name="id" type="string" source="=response.id" var="id2" />
          <uipath:output name="response" type="jsonSchema" source="=response" var="response3" />
          <uipath:output name="Error" type="jsonSchema" source="=Error" var="error4" />
        </uipath:activity>
      </bpmn:extensionElements>
      <bpmn:incoming>edge_Zs162I</bpmn:incoming>
      <bpmn:outgoing>edge_hWpaQl</bpmn:outgoing>
    </bpmn:sendTask>
    <bpmn:endEvent id="Event_OVZoBF">
      <bpmn:incoming>edge_hWpaQl</bpmn:incoming>
      <bpmn:incoming>edge_jDpSqC</bpmn:incoming>
    </bpmn:endEvent>
